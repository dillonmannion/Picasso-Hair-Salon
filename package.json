{
	"name": "picasso",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev --open",
		"dev:host": "vite dev --host",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync",
		"type-check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --threshold error",
		"type-check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"format": "prettier --write .",
		"format:check": "prettier --check .",
		"lint": "eslint . --max-warnings 100",
		"lint:fix": "eslint . --fix",
		"check": "pnpm run format:check && pnpm run lint && pnpm run type-check",
		"check:fix": "pnpm run format && pnpm run lint:fix",
		"test:unit": "vitest",
		"test:unit:ui": "vitest --ui",
		"test:unit:coverage": "vitest --coverage",
		"test:e2e": "playwright test",
		"test:e2e:ui": "playwright test --ui",
		"test:e2e:headed": "playwright test --headed",
		"test": "pnpm run test:unit --run && pnpm run test:e2e",
		"ci": "pnpm run check && pnpm run build && pnpm run test",
		"seed": "tsx scripts/seed.ts",
		"seed:prod": "NODE_ENV=production tsx scripts/seed.ts",
		"db:apply": "tsx scripts/apply-schema.ts",
		"postinstall": "svelte-kit sync"
	},
	"devDependencies": {
		"@eslint/compat": "^1.3.2",
		"@eslint/js": "^9.33.0",
		"@inlang/paraglide-js": "^2.2.0",
		"@internationalized/date": "^3.8.2",
		"@lucide/svelte": "^0.515.0",
		"@playwright/test": "^1.54.2",
		"@supabase/ssr": "^0.6.1",
		"@supabase/supabase-js": "^2.54.0",
		"@sveltejs/adapter-vercel": "^5.8.2",
		"@sveltejs/kit": "^2.27.3",
		"@sveltejs/vite-plugin-svelte": "^5.1.1",
		"@tailwindcss/forms": "^0.5.10",
		"@tailwindcss/typography": "^0.5.16",
		"@tailwindcss/vite": "^4.1.11",
		"@testing-library/jest-dom": "^6.6.4",
		"@testing-library/svelte": "^5.2.8",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^24.2.1",
		"autoprefixer": "^10.4.21",
		"bits-ui": "^2.9.2",
		"clsx": "^2.1.1",
		"date-fns": "^4.1.0",
		"dotenv": "^16.6.1",
		"eslint": "^9.33.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.11.0",
		"eslint-plugin-unicorn": "^59.0.1",
		"formsnap": "^2.0.1",
		"globals": "^16.3.0",
		"jsdom": "^26.1.0",
		"lucide-svelte": "^0.517.0",
		"mode-watcher": "^1.1.0",
		"postcss": "^8.5.6",
		"prettier": "^3.6.2",
		"prettier-plugin-svelte": "^3.4.0",
		"prettier-plugin-tailwindcss": "^0.6.14",
		"svelte": "^5.38.0",
		"svelte-check": "^4.3.1",
		"svelte-sonner": "^1.0.5",
		"sveltekit-superforms": "^2.27.1",
		"tailwind-merge": "^3.3.1",
		"tailwind-variants": "^1.0.0",
		"tailwindcss": "^4.1.11",
		"tsx": "^4.20.3",
		"tw-animate-css": "^1.3.6",
		"typescript": "^5.9.2",
		"typescript-eslint": "^8.39.1",
		"vite": "^6.3.5",
		"vitest": "^3.2.4",
		"zod": "^3.25.76"
	},
	"dependencies": {
		"@stripe/stripe-js": "^7.8.0",
		"stripe": "^18.4.0"
	}
}
