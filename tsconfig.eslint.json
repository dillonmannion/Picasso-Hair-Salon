{
	"extends": "./tsconfig.json",
	"include": [
		"src/**/*.js",
		"src/**/*.ts",
		"src/**/*.svelte",
		"tests/**/*.js",
		"tests/**/*.ts",
		"tests/**/*.svelte",
		"*.config.js",
		"*.config.ts",
		"*.config.mjs",
		"eslint.config.js"
	],
	"exclude": ["node_modules", "build", ".svelte-kit", "dist", "coverage"]
}
