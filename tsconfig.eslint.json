{
	"extends": "./tsconfig.json",
	"include": [
		"src/**/*.js",
		"src/**/*.ts",
		"src/**/*.svelte",
		"src/**/*.svelte.ts",
		"src/**/*.svelte.js",
		"vitest-setup.ts"
	],
	"exclude": [
		"node_modules",
		"build",
		".svelte-kit",
		"dist",
		"coverage",
		"test-results",
		"playwright-report",
		"**/*.test.ts",
		"**/*.spec.ts",
		"**/*.test.js",
		"**/*.spec.js",
		"tests/**",
		"e2e/**",
		"docs/**",
		"scripts/**",
		"database/**",
		"*.config.js",
		"*.config.ts",
		"*.config.mjs"
	]
}
