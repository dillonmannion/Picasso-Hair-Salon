# WARNING: Never commit real credentials to version control!
# This file serves as a template. Copy it to .env and fill in your actual values.

# Supabase Configuration
# Supabase URL for your project
PUBLIC_SUPABASE_URL=https://abcdefghijk.supabase.co
# Supabase anon key (safe to expose)
PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6ImFiY2RlZmdoaWprIiwicm9sZSI6ImFub24iLCJpYXQiOjE2NDY5MzcyMDAsImV4cCI6MTk2MjUxMzIwMH0.sample_anon_key
# IMPORTANT: The anon key is meant to be public and safe to use in client-side code

# Database Configuration
# Database connection string for migrations
DATABASE_URL=postgresql://postgres:password@localhost:54322/postgres

# Application Settings
# Environment mode (development, production, test)
NODE_ENV=development
# Public application URL
PUBLIC_APP_URL=http://localhost:5173
# Application name
PUBLIC_APP_NAME="Picasso Hair Salon"

# Security Settings
# Rate limit window in milliseconds (15 minutes = 900000ms)
RATE_LIMIT_WINDOW_MS=900000
# Rate limit max requests allowed per IP within the window
RATE_LIMIT_MAX_REQUESTS=100
# Session duration in hours
SESSION_DURATION_HOURS=24

# Authentication Providers (Optional)
# GitHub OAuth
SUPABASE_AUTH_GITHUB_CLIENT_ID=your-github-client-id
SUPABASE_AUTH_GITHUB_SECRET=your-github-secret
# Google OAuth
SUPABASE_AUTH_GOOGLE_CLIENT_ID=your-google-client-id
SUPABASE_AUTH_GOOGLE_SECRET=your-google-secret

# Testing
# Test user credentials for E2E tests
TEST_USER_EMAIL=test@example.com
TEST_USER_PASSWORD=test123
# Base URL for Playwright tests
PLAYWRIGHT_BASE_URL=http://localhost:5173

# Deployment (Vercel)
# Vercel environment variables for local development
VERCEL_ENV=development
VERCEL_URL=http://localhost:5173

# Service Keys (Server-side only)
# WARNING: Never expose service role keys in client-side code!
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
SUPABASE_DB_PASSWORD=your-db-password